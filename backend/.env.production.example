NODE_ENV=production
PORT=5000

# Public frontend origin (single origin expected by current CORS setup)
FRONTEND_URL=https://www.yourdomain.com

# Public backend origin (used for legacy upload links in emails during migration)
BACKEND_PUBLIC_URL=https://api.yourdomain.com

# MongoDB
MONGO_URI=mongodb+srv://<db_user>:<db_password>@<cluster>/<database>?retryWrites=true&w=majority

# Auth
JWT_SECRET=replace_with_a_long_random_secret_min_64_chars
JWT_EXPIRES_IN=7d

# SMTP (optional fallback if you still want it)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=no-reply@yourdomain.com
SMTP_PASS=replace_with_smtp_app_password_or_provider_secret
ADMIN_EMAIL=admin@yourdomain.com

# Rate limiting (use Redis for multi-instance deployments)
REDIS_URL=redis://:<redis_password>@<redis_host>:6379/0
RATE_LIMIT_PREFIX=deetech:rl

# Cloudinary (production media storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Hubtel (automatic checkout)
HUBTEL_API_ID=your_hubtel_api_id
HUBTEL_API_KEY=your_hubtel_api_key
HUBTEL_MERCHANT_ACCOUNT=your_hubtel_merchant_or_pos_account
HUBTEL_BASE_URL=https://payproxyapi.hubtel.com
HUBTEL_CALLBACK_TOKEN=replace_with_long_random_callback_token
HUBTEL_STATUS_TOKEN=replace_with_long_random_status_signing_token

# EmailJS (backend-triggered order + reset emails)
EMAILJS_SERVICE_ID=replace_with_emailjs_service_id
EMAILJS_PUBLIC_KEY=replace_with_emailjs_public_key
EMAILJS_ORDER_TEMPLATE_ID=replace_with_customer_order_template_id
EMAILJS_ADMIN_ORDER_TEMPLATE_ID=replace_with_admin_order_template_id
EMAILJS_RESET_SERVICE_ID=replace_with_reset_service_id
EMAILJS_RESET_PUBLIC_KEY=replace_with_reset_emailjs_public_key
EMAILJS_RESET_PRIVATE_KEY=replace_with_reset_emailjs_private_key
EMAILJS_RESET_TEMPLATE_ID=replace_with_reset_template_id
EMAILJS_PRIVATE_KEY=replace_with_emailjs_private_key
